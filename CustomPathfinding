getgenv().PathToLoop = function()
	if getgenv().PathfindingThread then
		task.cancel(getgenv().PathfindingThread)
	end

	getgenv().PathfindingThread = task.spawn(function()
		local Players = game:GetService("Players")
		local RunService = game:GetService("RunService")
		local ReplicatedStorage = game:GetService("ReplicatedStorage")
		
		local Player = Players.LocalPlayer
		local Character = Player.Character or Player.CharacterAdded:Wait()
		local Root = Character:WaitForChild("HumanoidRootPart")
		local Humanoid = Character:WaitForChild("Humanoid")

		local Visuals = workspace:FindFirstChild("CustomPathfinding") or Instance.new("Folder", workspace)
		Visuals.Name = "CustomPathfinding"

		local GridSize = 4
		local CurrentPath = {}
		local TargetPosition = nil

		local Params = RaycastParams.new()
		Params.FilterDescendantsInstances = {Character, Visuals}
		Params.FilterType = Enum.RaycastFilterType.Exclude
		Params.RespectCanCollide = true

		local function IsPassable(pos, target)
			local diff = (target - pos)
			local wallCheck = workspace:Raycast(pos + Vector3.new(0, 1.5, 0), diff, Params)
			if wallCheck and wallCheck.Instance and wallCheck.Instance.CanCollide then
				local name = wallCheck.Instance.Name:lower()
				if not (name:find("stair") or name:find("step") or name:find("wedge")) then
					return false
				end
			end
			return true
		end

		local function GetNeighbors(Pos)
			local Neighbors = {}
			local Directions = {
				Vector3.new(GridSize, 0, 0), Vector3.new(-GridSize, 0, 0),
				Vector3.new(0, 0, GridSize), Vector3.new(0, 0, -GridSize),
				Vector3.new(GridSize, 0, GridSize), Vector3.new(-GridSize, 0, -GridSize),
				Vector3.new(GridSize, 0, -GridSize), Vector3.new(-GridSize, 0, GridSize)
			}
			
			for _, Dir in Directions do
				local NeighborPos = Pos + Dir
				if IsPassable(Pos, NeighborPos) then
					local Floor = workspace:Raycast(NeighborPos + Vector3.new(0, 12, 0), Vector3.new(0, -24, 0), Params)
					if Floor then
						table.insert(Neighbors, Floor.Position)
					end
				end
			end
			return Neighbors
		end

		task.spawn(function()
			while task.wait(0.25) do
    if not getgenv().PathfindingThread then break end
				local LatestRoom = ReplicatedStorage.GameData.LatestRoom.Value
				local Room = workspace.CurrentRooms:FindFirstChild(tostring(LatestRoom))
				if not Room then continue end

				local HasKey = Character:FindFirstChild("Key") or Player.Backpack:FindFirstChild("Key")
				local KeyObj = Room:FindFirstChild("KeyObtain", true)
				local FinalTarget = nil

				if KeyObj and not HasKey then
					FinalTarget = KeyObj:IsA("Model") and KeyObj.PrimaryPart and KeyObj.PrimaryPart.Position or KeyObj:IsA("BasePart") and KeyObj.Position
					if FinalTarget and (Root.Position - FinalTarget).Magnitude < 13 then
						local Prompt = KeyObj:FindFirstChildWhichIsA("ProximityPrompt", true)
						if Prompt then fireproximityprompt(Prompt) end
					end
				elseif Room:FindFirstChild("Door") and Room.Door:FindFirstChild("Door") then
					FinalTarget = Room.Door.Door.Position
					if (Root.Position - FinalTarget).Magnitude < 15 then
						local DoorPrompt = Room.Door:FindFirstChildWhichIsA("ProximityPrompt", true)
						if DoorPrompt then fireproximityprompt(DoorPrompt) end
						local Lock = Room.Door:FindFirstChild("Lock")
						if Lock then
							local LockPrompt = Lock:FindFirstChildWhichIsA("ProximityPrompt", true)
							if LockPrompt then fireproximityprompt(LockPrompt) end
						end
					end
				end

				if FinalTarget then
					TargetPosition = FinalTarget
					local Start = Vector3.new(math.round(Root.Position.X/GridSize)*GridSize, Root.Position.Y, math.round(Root.Position.Z/GridSize)*GridSize)
					local Goal = Vector3.new(math.round(FinalTarget.X/GridSize)*GridSize, FinalTarget.Y, math.round(FinalTarget.Z/GridSize)*GridSize)

					local Open = {Start}
					local Closed = {}
					local CameFrom = {}
					local GScore = {[Start] = 0}
					local FScore = {[Start] = (Start - Goal).Magnitude}
					local Success = false
					
					for I = 1, 300 do
						local CurrentIdx = 1
						for J = 2, #Open do
							if FScore[Open[J]] < FScore[Open[CurrentIdx]] then CurrentIdx = J end
						end
						
						local Current = table.remove(Open, CurrentIdx)
						if not Current then break end
						if (Current - Goal).Magnitude < GridSize * 1.5 then
							Goal = Current
							Success = true
							break
						end
						
						Closed[Current] = true
						for _, Neighbor in GetNeighbors(Current) do
							if Closed[Neighbor] then continue end
							local Score = GScore[Current] + (Current - Neighbor).Magnitude
							if not GScore[Neighbor] or Score < GScore[Neighbor] then
								CameFrom[Neighbor] = Current
								GScore[Neighbor] = Score
								FScore[Neighbor] = Score + (Neighbor - Goal).Magnitude
								if not table.find(Open, Neighbor) then table.insert(Open, Neighbor) end
							end
						end
					end

					if Success then
						local NewPath = {}
						local Curr = Goal
						Visuals:ClearAllChildren()
						while Curr do
							table.insert(NewPath, 1, Curr)
							local Marker = Instance.new("Part", Visuals)
							Marker.Size, Marker.Shape, Marker.Color, Marker.Material = Vector3.new(0.6,0.6,0.6), "Ball", Color3.new(1,0.5,0), "Neon"
							Marker.Anchored, Marker.CanCollide, Marker.Position = true, false, Curr
							Curr = CameFrom[Curr]
						end
						CurrentPath = NewPath
					end
				end
			end
		end)

		local con = RunService.RenderStepped:Connect(function()
if not getgenv().PathfindingThread then
con:Disconnect()
end
			if #CurrentPath > 0 then
				local Target = CurrentPath[1]
				Humanoid:MoveTo(Target)
				if (Root.Position - Target).Magnitude < 3.8 then
					table.remove(CurrentPath, 1)
				end
			elseif TargetPosition then
				Humanoid:MoveTo(TargetPosition)
			end
		end)
	end)
end

PathToLoop()
