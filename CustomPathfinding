getgenv().PathToLoop = function()
    if getgenv().PathfindingThread then
        task.cancel(getgenv().PathfindingThread)
    end

    getgenv().PathfindingThread = task.spawn(function()
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        
        local Player = Players.LocalPlayer
        local Character = Player.Character or Player.CharacterAdded:Wait()
        local Root = Character:WaitForChild("HumanoidRootPart")
        local Humanoid = Character:WaitForChild("Humanoid")

        local Visuals = workspace:FindFirstChild("CustomPath") or Instance.new("Folder", workspace)
        Visuals.Name = "CustomPath"

        local GridSize = 4
        local CurrentPath = {}
        local TargetPosition = nil

        local function IsPassable(Part)
            if not Part then return true end
            if not Part.CanCollide or Part.Transparency >= 0.7 or not Part.CanQuery then return true end
            
            
            return false
        end

        local function CheckCollision(Start, End)
            local Params = RaycastParams.new()
            Params.FilterDescendantsInstances = {Character, Visuals}
            Params.FilterType = Enum.RaycastFilterType.Exclude
            
            local Direction = End - Start
            local Distance = Direction.Magnitude
            if Distance == 0 then return false end
            
            local Size = Vector3.new(2, 4.5, 2)
            local CFrameStart = CFrame.new(Start + Vector3.new(0, 2.5, 0), End + Vector3.new(0, 2.5, 0))
            
            local Result = workspace:Blockcast(CFrameStart, Size, Direction, Params)
            
            if Result and Result.Instance and not IsPassable(Result.Instance) then
                return true
            end
            return false
        end

        local function GetNeighbors(Pos)
            local Neighbors = {}
            local Directions = {
                Vector3.new(GridSize, 0, 0), Vector3.new(-GridSize, 0, 0),
                Vector3.new(0, 0, GridSize), Vector3.new(0, 0, -GridSize),
                Vector3.new(GridSize, 0, GridSize), Vector3.new(-GridSize, 0, -GridSize),
                Vector3.new(GridSize, 0, -GridSize), Vector3.new(-GridSize, 0, GridSize)
            }
            
            for _, Dir in Directions do
                local NeighborPos = Pos + Dir
                if not CheckCollision(Pos, NeighborPos) then
                    local Params = RaycastParams.new()
                    Params.FilterDescendantsInstances = {Character, Visuals}
                    Params.FilterType = Enum.RaycastFilterType.Exclude
                    
                    local Floor = workspace:Raycast(NeighborPos + Vector3.new(0, 5, 0), Vector3.new(0, -10, 0), Params)
                    if Floor then
                        table.insert(Neighbors, Floor.Position)
                    end
                end
            end
            return Neighbors
        end

        local function ToKey(Vec)
            return math.floor(Vec.X/2) .. "," .. math.floor(Vec.Y/2) .. "," .. math.floor(Vec.Z/2)
        end

        task.spawn(function()
            while task.wait(0.35) do
                if not getgenv().PathfindingThread then break end
                
                local LatestRoom = ReplicatedStorage.GameData.LatestRoom.Value
                local Room = workspace.CurrentRooms:FindFirstChild(tostring(LatestRoom))
                if not Room then continue end

                local HasKey = Character:FindFirstChild("Key") or Player.Backpack:FindFirstChild("Key")
                local KeyObj = Room:FindFirstChild("KeyObtain", true)
                local FinalTarget = nil

                if KeyObj and not HasKey then
                    FinalTarget = KeyObj:IsA("Model") and KeyObj.PrimaryPart and KeyObj.PrimaryPart.Position or KeyObj:IsA("BasePart") and KeyObj.Position
                elseif Room:FindFirstChild("Door") then
                    local DoorMain = Room.Door:FindFirstChild("Door") or Room.Door:FindFirstChild("Hidden")
                    if DoorMain then FinalTarget = DoorMain.Position end
                end

                if FinalTarget then
                    TargetPosition = FinalTarget
                    local Start = Root.Position
                    
                    local Open = {Start}
                    local Closed = {}
                    local CameFrom = {}
                    local GScore = {[ToKey(Start)] = 0}
                    local FScore = {[ToKey(Start)] = (Start - FinalTarget).Magnitude}
                    
                    local Success = false
                    for I = 1, 1500 do
                        local CurrentIdx = 1
                        local minF = math.huge
                        for j, node in ipairs(Open) do
                            local f = FScore[ToKey(node)] or math.huge
                            if f < minF then minF = f; CurrentIdx = j end
                        end
                        
                        local Current = table.remove(Open, CurrentIdx)
                        if not Current then break end
                        
                        if (Current - FinalTarget).Magnitude < GridSize * 1.5 then
                            FinalTarget = Current
                            Success = true
                            break
                        end
                        
                        Closed[ToKey(Current)] = true
                        for _, Neighbor in GetNeighbors(Current) do
                            if Closed[ToKey(Neighbor)] then continue end
                            local tentative_g = GScore[ToKey(Current)] + (Current - Neighbor).Magnitude
                            
                            if not GScore[ToKey(Neighbor)] or tentative_g < GScore[ToKey(Neighbor)] then
                                CameFrom[ToKey(Neighbor)] = Current
                                GScore[ToKey(Neighbor)] = tentative_g
                                FScore[ToKey(Neighbor)] = tentative_g + (Neighbor - FinalTarget).Magnitude
                                if not table.find(Open, Neighbor) then table.insert(Open, Neighbor) end
                            end
                        end
                    end

                    if Success then
                        local NewPath = {}
                        local Curr = FinalTarget
                        while Curr do
                            table.insert(NewPath, 1, Curr)
                            Curr = CameFrom[ToKey(Curr)]
                        end
                        CurrentPath = NewPath
                        
                        Visuals:ClearAllChildren()
                        for _, p in pairs(NewPath) do
                            local m = Instance.new("Part", Visuals)
                            m.Size, m.Anchored, m.CanCollide, m.Position, m.Color, m.Shape, m.Material = Vector3.new(0.6,0.6,0.6), true, false, p, Color3.fromRGB(0, 255, 255), "Ball", "Neon"
                        end
                    end
                end
            end
        end)

        local con; con = RunService.RenderStepped:Connect(function()
            if not getgenv().PathfindingThread then con:Disconnect() return end
            
            if #CurrentPath > 0 then
                local TargetNode = CurrentPath[1]
                
                if CurrentPath[2] and not CheckCollision(Root.Position, CurrentPath[2]) then
                    table.remove(CurrentPath, 1)
                    TargetNode = CurrentPath[1]
                end

                Humanoid:MoveTo(TargetNode)
                
                if (Root.Position * Vector3.new(1,0,1) - TargetNode * Vector3.new(1,0,1)).Magnitude < 2.5 then
                    table.remove(CurrentPath, 1)
                end
            elseif TargetPosition then
                Humanoid:MoveTo(TargetPosition)
            end
        end)
    end)
end

PathToLoop()
