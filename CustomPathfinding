getgenv().PathToLoop = function()
    if getgenv().PathfindingThread then
        task.cancel(getgenv().PathfindingThread)
    end

    getgenv().PathfindingThread = task.spawn(function()
        local PathfindingService = game:GetService("PathfindingService")
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        
        local Player = Players.LocalPlayer
        local Character = Player.Character or Player.CharacterAdded:Wait()
        local Root = Character:WaitForChild("HumanoidRootPart")
        local Humanoid = Character:WaitForChild("Humanoid")

        local Waypoints = {}
        local CurrentWaypointIndex = 0
        local LastPosition = Root.Position
        local StuckTime = 0
        local CurrentTarget = nil

        local Path = PathfindingService:CreatePath({
            AgentRadius = 0.01,
            AgentHeight = 5,
            AgentCanJump = true,
            WaypointSpacing = 2
        })

        local function ComputePath(TargetPos)
            local success, _ = pcall(function()
                Path:ComputeAsync(Root.Position, TargetPos)
            end)

            if success and Path.Status == Enum.PathStatus.Success then
                Waypoints = Path:GetWaypoints()
                CurrentWaypointIndex = 1
            else
                Humanoid:MoveTo(TargetPos)
            end
        end

        task.spawn(function()
            while task.wait(0.4) do
                if not getgenv().PathfindingThread then break end
                
                local LatestRoom = ReplicatedStorage.GameData.LatestRoom.Value
                local Room = workspace.CurrentRooms:FindFirstChild(tostring(LatestRoom))
                if not Room then continue end

                local HasKey = Character:FindFirstChild("Key") or Player.Backpack:FindFirstChild("Key")
                local KeyObj = Room:FindFirstChild("KeyObtain", true)
                local FinalTarget = nil

                if KeyObj and not HasKey then
                    FinalTarget = (KeyObj:IsA("Model") and KeyObj.PrimaryPart or KeyObj).Position
                elseif Room:FindFirstChild("Door") then
                    local DoorMain = Room.Door:FindFirstChild("Door") or Room.Door:FindFirstChild("Hidden")
                    if DoorMain then FinalTarget = DoorMain.Position end
                end

                if FinalTarget then
                    CurrentTarget = FinalTarget
                    ComputePath(FinalTarget)
                end
            end
        end)

        local con; con = RunService.RenderStepped:Connect(function()
            if not getgenv().PathfindingThread then con:Disconnect() return end
            
            if Waypoints and CurrentWaypointIndex <= #Waypoints then
                local targetWaypoint = Waypoints[CurrentWaypointIndex]
                
                if (Root.Position - LastPosition).Magnitude < 0.1 then
                    StuckTime = StuckTime + task.wait()
                    if StuckTime > 0.4 then
                        if CurrentTarget then
                            ComputePath(CurrentTarget)
                        end
                        Humanoid.Jump = true
                        StuckTime = 0
                    end
                else
                    StuckTime = 0
                end
                LastPosition = Root.Position

                if targetWaypoint.Action == Enum.PathWaypointAction.Jump then
                    Humanoid.Jump = true
                end

                Humanoid:MoveTo(targetWaypoint.Position)

                if (Root.Position - targetWaypoint.Position).Magnitude < 2 then
                    CurrentWaypointIndex = CurrentWaypointIndex + 1
                end
            end
        end)
    end)
end

PathToLoop()
