local Support = {}
local Workspace = cloneref and cloneref(game:GetService("Workspace")) or game:GetService("Workspace")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ExecutorName = identifyexecutor() or getexecutorname() or "Unknown"
local LocalPlayer = Players.LocalPlayer

if not LocalPlayer.Character then
print("Waiting for character to load")
repeat task.wait() until LocalPlayer.Character
end



  
local function run(f, ...)
	local ok, res = pcall(f, ...)
	return ok and res
end

local function checkProximity()
	if not fireproximityprompt then return false end
	
	local folder = Instance.new("Folder", Workspace)
	local part = Instance.new("Part", folder)
	part.Anchored = true
	part.Position = Vector3.new(0, 5000, 0)
	
	local prompt = Instance.new("ProximityPrompt", part)
	prompt.Enabled = true
	prompt.MaxActivationDistance = 1000
	prompt.RequiresLineOfSight = false
	
	local done = false
	local connection = prompt.Triggered:Connect(function()
		done = true
	end)
	
	pcall(function()
		fireproximityprompt(prompt, 0)
	end)
	
	task.wait(0.5)
	
	connection:Disconnect()
	folder:Destroy()
	
	return done
end

local function checkTouch()
	if not firetouchinterest then return false end
local Touched = false
local TestPart = Instance.new("Part", workspace)
TestPart.Name = "TestPart"
local Part = Instance.new("Part",workspace)

Part.Position = Vector3.new(0, 100, 0)
Part.CanTouch = true
Part.Anchored = true
Part.CanCollide = true


 local con = Part.Touched:Connect(function()
Touched = true
end)
local timeout = 0

while timeout < 1 do
timeout += RunService.RenderStepped:Wait()
firetouchinterest(TestPart, Part, 0)
task.wait()
firetouchinterest(TestPart, Part, 1)
task.wait()
end
task.wait(1)
Part:Destroy()
TestPart:Destroy()
con:Disconnect()
return Touched
end

local function checkRequire()
if ExecutorName == "Xeno" or ExecutorName == "Seliware" then
return false
end
if ExecutorName ~=  "Xeno" or ExecutorName ~= "Seliware" then
	local scripts = Players.LocalPlayer:FindFirstChild("PlayerScripts")
	if scripts then
		local mod = scripts:FindFirstChild("PlayerModule")
		if mod then
			local ok, res = pcall(require, mod)
			return ok and type(res) == "table"
		end
	end
end
	return false
end

local function checkSignal()
	return type(replicatesignal) == "function"
end

local function checkHook()
	if not hookmetamethod then return false end
	
	local testObj = game
	local called = false
	local original
	
	local ok = pcall(function()
		original = hookmetamethod(testObj, "__index", function(self, key)
			if key == "DetectionTest" then
				called = true
				return true
			end
			return original(self, key)
		end)
	end)
	
	if ok then
		local _ = testObj.DetectionTest
		hookmetamethod(testObj, "__index", original)
	end
	
	return called
end
local function checkisnetworkowner()
if isnetworkowner then
local Part = Instance.new("Part", workspace)
if isnetworkowner(Part) then
return true
else
return false
end
Part:Destroy()

end
if not isnetworkowner then
return false
end

end


local tests = {
	{id = "fireproximityprompt", run = checkProximity},
	{id = "firetouchinterest", run = checkTouch},
	{id = "require", run = checkRequire},
	{id = "replicatesignal", run = checkSignal},
	{id = "hookmetamethod", run = checkHook},
    {id = "isnetworkowner", run = checkisnetworkowner},
}

local score = 0
print("--- Starting compatibility check ---")

for _, t in pairs(tests) do
	local success = run(t.run)
	Support[t.id] = success or false
	
	local icon = success and "🟢" or "🔴"
	print(icon .. " " .. t.id)
	
	if success then score = score + 1 end
end

local resultStr = string.format("Results: %d/%d (%d%%)", score, #tests, math.floor((score / #tests) * 100))
print("-----------------------------------")
print(resultStr)

if getgenv then
	getgenv().ExecutorSupport = Support
end


return Support
