local Support = {}
local Workspace = cloneref and cloneref(game:GetService("Workspace")) or game:GetService("Workspace")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local function safeCall(func, ...)
	local success = pcall(func, ...)
	return success
end

local function testFireProximityPrompt()
	local folder = Instance.new("Folder")
	folder.Name = "ExecutorSupportTest"
	folder.Parent = Workspace
	local part = Instance.new("Part")
	part.Anchored = true
	part.Position = Vector3.new(0, 1e6, 0)
	part.Parent = folder
	local prompt = Instance.new("ProximityPrompt")
	prompt.MaxActivationDistance = 1000
	prompt.RequiresLineOfSight = false
	prompt.Parent = part
	local triggered = false
	local conn = prompt.Triggered:Connect(function()
		triggered = true
	end)
	local success = pcall(function()
		fireproximityprompt(prompt, 0)
	end)
	if success then
		local start = os.clock()
		repeat
			RunService.Heartbeat:Wait()
		until triggered or os.clock() - start > 0.5
	end
	conn:Disconnect()
	folder:Destroy()
	return triggered
end

local function testFireTouchInterest()
	local folder = Instance.new("Folder")
	folder.Name = "ExecutorSupportTest"
	folder.Parent = Workspace
	local partA = Instance.new("Part")
	partA.Anchored = true
	partA.Position = Vector3.new(0, 1e6, 0)
	partA.Parent = folder
	local partB = Instance.new("Part")
	partB.Anchored = true
	partB.Position = Vector3.new(0, 1e6, 0)
	partB.Parent = folder
	local transmitter = Instance.new("TouchTransmitter")
	transmitter.Parent = partA
	local touched = false
	local conn = partB.Touched:Connect(function()
		touched = true
	end)
	local success = pcall(function()
		firetouchinterest(Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart"), partB, 0)
	end)
	if success then
		local start = os.clock()
		repeat
			RunService.Heartbeat:Wait()
		until touched or os.clock() - start > 0.5
	end
	conn:Disconnect()
	folder:Destroy()
	return touched
end

local function testRequire()
	local playerModule = Players.LocalPlayer:WaitForChild("PlayerScripts"):FindFirstChild("PlayerModule")
	if playerModule then
		local success, result = pcall(function()
			return require(playerModule)
		end)
		if success and type(result) == "table" then
			return true
		end
	end
	for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
		if obj:IsA("ModuleScript") then
			local success, result = pcall(function()
				return require(obj)
			end)
			if success and type(result) ~= "nil" then
				return true
			end
		end
	end
	local dummy = Instance.new("ModuleScript")
	dummy.Source = "return {__test = true}"
	dummy.Parent = Workspace
	local success, result = pcall(function()
		return require(dummy)
	end)
	dummy:Destroy()
	return success and type(result) == "table" and result.__test == true
end

local function testReplicateSignal()
	local remote = Instance.new("RemoteEvent")
	remote.Parent = ReplicatedStorage
	local success = pcall(function()
		replicatesignal(remote, "test")
	end)
	remote:Destroy()
	return success
end

Support.fireproximityprompt = safeCall(testFireProximityPrompt) and true or false
Support.firetouchinterest = safeCall(testFireTouchInterest) and true or false
Support.require = safeCall(testRequire) and true or false
Support.replicatesignal = safeCall(testReplicateSignal) and true or false

getgenv().ExecutorSupport = Support
return Support
