local Support = {}
local Workspace = cloneref and cloneref(game:GetService("Workspace")) or game:GetService("Workspace")

local function run(f, ...)
    local ok, res = pcall(f, ...)
    return ok and res
end

local function checkProximity()
    if type(fireproximityprompt) ~= "function" then return "RED" end
    local p = Instance.new("Part")
    local pr = Instance.new("ProximityPrompt", p)
    local d = false
    local c = pr.Triggered:Connect(function() d = true end)
    fireproximityprompt(pr)
    task.wait(0.1)
    c:Disconnect()
    p:Destroy()
    return d and "GREEN" or "YELLOW"
end

local function checkTouch()
    if type(firetouchinterest) ~= "function" then return "RED" end
    local t = false
    local a, b = Instance.new("Part", Workspace), Instance.new("Part", Workspace)
    local c = a.Touched:Connect(function() t = true end)
    firetouchinterest(a, b, 0)
    task.wait(0.1)
    firetouchinterest(a, b, 1)
    c:Disconnect()
    a:Destroy()
    b:Destroy()
    return t and "GREEN" or "YELLOW"
end

local function checkHookMeta()
    if type(hookmetamethod) ~= "function" then return "RED" end
    local c = false
    local o
    local s = pcall(function()
        o = hookmetamethod(game, "__index", function(self, k)
            if not checkcaller() and k == "Check" then c = true return true end
            return o(self, k)
        end)
        local _ = game.Check
    end)
    return (s and c) and "GREEN" or "YELLOW"
end

local function checkHookFunc()
    if type(hookfunction) ~= "function" then return "RED" end
    local t = function() return false end
    local s = pcall(function() hookfunction(t, function() return true end) end)
    return (s and t() == true) and "GREEN" or "YELLOW"
end

local function checkReadOnly()
    if type(setreadonly) ~= "function" or type(isreadonly) ~= "function" then return "RED" end
    local t = {}
    table.freeze(t)
    setreadonly(t, false)
    return isreadonly(t) == false and "GREEN" or "YELLOW"
end

local function checkGenv()
    if type(getgenv) ~= "function" then return "RED" end
    getgenv().V = 1
    local s = getgenv().V == 1
    getgenv().V = nil
    return s and "GREEN" or "YELLOW"
end

local function checkRenv()
    if type(getrenv) ~= "function" then return "RED" end
    local r = getrenv()
    return (type(r) == "table" and r.game) and "GREEN" or "YELLOW"
end

local function checkGC()
    if type(getgc) ~= "function" then return "RED" end
    local g = getgc()
    return (type(g) == "table" and #g > 0) and "GREEN" or "YELLOW"
end

local function checkReg()
    local f = getreg or getregistry
    if type(f) ~= "function" then return "RED" end
    local r = f()
    return (type(r) == "table" and #r > 0) and "GREEN" or "YELLOW"
end

local function checkScripts()
    local f = getscripts or getrunningscripts
    if type(f) ~= "function" then return "RED" end
    return type(f()) == "table" and "GREEN" or "YELLOW"
end

local function checkConn()
    if type(getconnections) ~= "function" then return "RED" end
    local p = Instance.new("Part")
    local c = p.Touched:Connect(function() end)
    local r = getconnections(p.Touched)
    local s = type(r) == "table" and #r > 0
    c:Disconnect()
    p:Destroy()
    return s and "GREEN" or "YELLOW"
end

local function checkDrawing()
    if type(Drawing) ~= "table" or type(Drawing.new) ~= "function" then return "RED" end
    local l = Drawing.new("Line")
    local s = (l and l.Remove)
    if s then l:Remove() end
    return s and "GREEN" or "YELLOW"
end

local function checkHidden()
    if type(gethiddenproperty) ~= "function" or type(sethiddenproperty) ~= "function" then return "RED" end
    local p = Instance.new("Part")
    sethiddenproperty(p, "Massless", true)
    local s = gethiddenproperty(p, "Massless") == true
    p:Destroy()
    return s and "GREEN" or "YELLOW"
end

local function checkIdentity()
    local g, s = getthreadidentity or getthreadcontext, setthreadidentity or setthreadcontext
    if not (g and s) then return "RED" end
    local o = g()
    s(3)
    local v = g() == 3
    s(o)
    return v and "GREEN" or "YELLOW"
end

local function checkClone()
    if type(cloneref) ~= "function" then return "RED" end
    local r = cloneref(game)
    return (type(r) == "userdata" and r ~= game) and "GREEN" or "YELLOW"
end

local function checkRequest()
    local r = request or http_request or (http and http.request)
    if type(r) ~= "function" then return "RED" end
    local res = r({Url = "https://google.com", Method = "GET"})
    return (type(res) == "table" and res.StatusCode == 200) and "GREEN" or "YELLOW"
end

local function checkFiles()
    if type(writefile) ~= "function" or type(readfile) ~= "function" then return "RED" end
    writefile("v.txt", "x")
    local s = readfile("v.txt") == "x"
    if type(delfile) == "function" then delfile("v.txt") end
    return s and "GREEN" or "YELLOW"
end

local function checkFolders()
    if type(makefolder) ~= "function" or type(delfolder) ~= "function" then return "RED" end
    makefolder("v_f")
    local s = isfolder and isfolder("v_f") or true
    delfolder("v_f")
    return s and "GREEN" or "YELLOW"
end

local function checkNil()
    if type(getnilinstances) ~= "function" then return "RED" end
    return type(getnilinstances()) == "table" and "GREEN" or "YELLOW"
end

local function checkHui()
    if type(gethui) ~= "function" then return "RED" end
    return gethui():IsA("Instance") and "GREEN" or "YELLOW"
end

local function checkRaw()
    if type(getrawmetatable) ~= "function" or type(setrawmetatable) ~= "function" then return "RED" end
    local t, m = {}, {__index = function() return 1 end}
    setrawmetatable(t, m)
    return t.x == 1 and "GREEN" or "YELLOW"
end

local function checkC()
    if type(newcclosure) ~= "function" or type(islclosure) ~= "function" then return "RED" end
    local f = newcclosure(function() return 1 end)
    return (islclosure(f) == false and f() == 1) and "GREEN" or "YELLOW"
end

local function checkDebug(name)
    if type(debug) ~= "table" or type(debug[name]) ~= "function" then return "RED" end
    local s = pcall(function() debug[name](checkDebug) end)
    return s and "GREEN" or "YELLOW"
end

local function checkHash()
    if type(getscripthash) ~= "function" then return "RED" end
    local s = pcall(function() getscripthash(LocalPlayer.CharacterAppearanceLoaded) end)
    return s and "GREEN" or "YELLOW"
end

local tests = {
    {id = "fireproximityprompt", run = checkProximity},
    {id = "firetouchinterest", run = checkTouch},
    {id = "hookmetamethod", run = checkHookMeta},
    {id = "hookfunction", run = checkHookFunc},
    {id = "setreadonly", run = checkReadOnly},
    {id = "getgenv", run = checkGenv},
    {id = "getrenv", run = checkRenv},
    {id = "getgc", run = checkGC},
    {id = "getreg", run = checkReg},
    {id = "getscripts", run = checkScripts},
    {id = "getconnections", run = checkConn},
    {id = "Drawing.new", run = checkDrawing},
    {id = "gethiddenproperty", run = checkHidden},
    {id = "sethiddenproperty", run = checkHidden},
    {id = "getthreadidentity", run = checkIdentity},
    {id = "cloneref", run = checkClone},
    {id = "request", run = checkRequest},
    {id = "writefile", run = checkFiles},
    {id = "readfile", run = checkFiles},
    {id = "makefolder", run = checkFolders},
    {id = "getnilinstances", run = checkNil},
    {id = "gethui", run = checkHui},
    {id = "getrawmetatable", run = checkRaw},
    {id = "setrawmetatable", run = checkRaw},
    {id = "newcclosure", run = checkC},
    {id = "islclosure", run = function() return type(islclosure) == "function" and "GREEN" or "RED" end},
    {id = "debug.getupvalues", run = function() return checkDebug("getupvalues") end},
    {id = "debug.getconstants", run = function() return checkDebug("getconstants") end},
    {id = "debug.getprotos", run = function() return checkDebug("getprotos") end},
    {id = "getscripthash", run = checkHash},
    {id = "identifyexecutor", run = function() return type(identifyexecutor) == "function" and "GREEN" or "RED" end},
    {id = "checkcaller", run = function() return type(checkcaller) == "function" and "GREEN" or "RED" end},
}

local score = 0
print("Starting Compatibility Check")
print("🟡 is Fake Function")

for _, t in pairs(tests) do
    local res = run(t.run)
    local icon = "🔴"
    if res == "GREEN" then
        icon = "🟢"
        score = score + 1
        Support[t.id] = true
    elseif res == "YELLOW" then
        icon = "🟡"
        Support[t.id] = false
    else
        Support[t.id] = false
    end
    print(string.format("%s [%s]", icon, t.id))
end

print("---------------------------------")
print(string.format("Results: %d/%d (%d%%)", score, #tests, math.floor((score / #tests) * 100)))

if getgenv and type(getgenv) == "function" then getgenv().ExecutorSupport = Support end
return Support
