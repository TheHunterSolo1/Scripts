local Library = {}
getgenv().ESPLibrary = Library

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Cache = {}
local Connection = nil

local Vector2New = Vector2.new
local Color3New = Color3.new
local DrawingNew = Drawing and Drawing.new

local Settings = {
    Tracers = false,
    Distance = false,
    MaxDistance = 5000,
    TextSize = 23,
    Font = Enum.Font.GothamBold,
    TracerThickness = 1
}

local function GetRoot(model)
    if model:IsA("BasePart") then return model end
    return model.PrimaryPart or model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildWhichIsA("BasePart")
end

function Library:SetFont(font)
    Settings.Font = font
    for _, data in pairs(Cache) do
        data.Label.Font = font
    end
end

function Library:SetTracersSize(num)
    Settings.TracerThickness = num
    for _, data in pairs(Cache) do
        if data.Tracer then data.Tracer.Thickness = num end
    end
end

function Library:SetTracers(bool) Settings.Tracers = bool end
function Library:ShowDistance(bool) Settings.Distance = bool end
function Library:SetMaxDistance(num) Settings.MaxDistance = num end

local function CreateVisuals(part, color, name)
    local root = GetRoot(part)
    if not root or root:IsDescendantOf(LocalPlayer.Character) then return nil end

    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = Color3New(1, 1, 1)
    highlight.FillTransparency = 0.5
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = part
    highlight.Enabled = false
    highlight.Parent = CoreGui -- Optimized parent

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3New(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled = false
    billboard.Adornee = root
    billboard.Parent = CoreGui

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.TextColor3 = color
    label.Font = Settings.Font
    label.TextSize = Settings.TextSize
    label.Text = name
    label.TextStrokeTransparency = 0
    label.Parent = billboard

    local tracer = nil
    if DrawingNew then
        tracer = DrawingNew("Line")
        tracer.Visible = false
        tracer.Color = color
        tracer.Thickness = Settings.TracerThickness
        tracer.Transparency = 1
    end

    return {
        Root = root,
        Highlight = highlight,
        Gui = billboard,
        Label = label,
        Tracer = tracer,
        Name = name,
        Active = false
    }
end

function Library:AddESP(part, name, color)
    if not part or Cache[part] then return end
    local data = CreateVisuals(part, color, name)
    if data then Cache[part] = data end
end

function Library:RemoveESP(part)
    local data = Cache[part]
    if data then
        data.Highlight:Destroy()
        data.Gui:Destroy()
        if data.Tracer then data.Tracer:Remove() end
        Cache[part] = nil
    end
end

local function Update()
    local CamCF = Camera.CFrame
    local CamPos = CamCF.Position
    local ViewportSize = Camera.ViewportSize
    local Center = Vector2New(ViewportSize.X / 2, ViewportSize.Y)
    
    for part, data in pairs(Cache) do
        local root = data.Root
        if not root or not root.Parent then
            if data.Active then
                data.Active = false
                data.Gui.Enabled = false
                data.Highlight.Enabled = false
                if data.Tracer then data.Tracer.Visible = false end
            end
            continue
        end

        local pos = root.Position
        local dist = (CamPos - pos).Magnitude

        if dist > Settings.MaxDistance then
            if data.Active then
                data.Active = false
                data.Gui.Enabled = false
                data.Highlight.Enabled = false
                if data.Tracer then data.Tracer.Visible = false end
            end
            continue
        end

        local screenPos, onScreen = Camera:WorldToViewportPoint(pos)

        if onScreen then
            if not data.Active then
                data.Active = true
                data.Gui.Enabled = true
                data.Highlight.Enabled = true
            end

            if Settings.Distance then
                data.Label.Text = data.Name .. "\n[" .. math.floor(dist) .. "]"
            else
                data.Label.Text = data.Name
            end

            if data.Tracer then
                if Settings.Tracers then
                    data.Tracer.Visible = true
                    data.Tracer.From = Center
                    data.Tracer.To = Vector2New(screenPos.X, screenPos.Y)
                else
                    data.Tracer.Visible = false
                end
            end
        else
            if data.Active then
                data.Active = false
                data.Gui.Enabled = false
                data.Highlight.Enabled = false
                if data.Tracer then data.Tracer.Visible = false end
            end
        end
    end
end

Connection = RunService.RenderStepped:Connect(Update)

function Library:Unload()
    if Connection then Connection:Disconnect() end
    for part in pairs(Cache) do Library:RemoveESP(part) end
    getgenv().ESPLibrary = nil
end

return Library
