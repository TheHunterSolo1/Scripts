function Library:Unload()
    if self.Connection then self.Connection:Disconnect() end
    for obj, _ in pairs(self.Cache) do 




self:RemoveESP(obj) 



end
    Screen:Destroy()
end


local Delay = tick()
 
Library.Connection = RS.PreRender:Connect(function(dt)

local Check = 1 / Library.Settings.RenderTime

if tick() - Check > Delay then
Delay = tick()
    
    local cam = workspace.CurrentCamera
    local camCF = cam.CFrame
    local viewportSize = cam.ViewportSize
    local screenCenter = viewportSize / 2
    local fovScale = (cam.FieldOfView) / 70
    local rainbowColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)

    for obj, data in pairs(Library.Cache) do
        if not obj or not obj.Parent then
            Library:RemoveESP(obj)
            continue
        end

        local root = GetRoot(obj)
        if not root then continue end

        local rootPos = root.Position
        
        
        local screenPos, onScreen = cam:WorldToViewportPoint(rootPos)
        local displayColor = Library.Settings.Rainbow and rainbowColor or data.Color
local dist = (data.Tag.CurrentDistance * 100) / 100

        data.Tag.Enabled = onScreen
        if onScreen then
            data.Text.TextColor3 = displayColor
            data.Text.TextSize = Library.Settings.TextSize * fovScale
            data.Text.Text = string.format("%s%s", data.Name, Library.Settings.Distance and string.format("\n[%dm]", math.floor(dist)) or "")
            data.Box.FillColor = displayColor
            data.Box.Enabled = (Library.Settings.ESPMode == "Highlight" and true or  Library.Settings.ESPMode == "Highlight/Text" and true or onScreen and true or false)
            data.Text.Visible = (Library.Settings.ESPMode == "Text" and true or  Library.Settings.ESPMode == "Highlight/Text" and true or onScreen and true or false)
            if Library.Settings.Tracers and dist < 1500 then
                local diff = Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(screenCenter.X, viewportSize.Y)
                data.Line.Visible = true
                data.Line.BackgroundColor3 = displayColor
                data.Line.Size = UDim2.new(0, diff.Magnitude, 0, 1)
                data.Line.Position = UDim2.new(0, screenCenter.X + diff.X / 2, 0, viewportSize.Y + diff.Y / 2)
                data.Line.Rotation = math.deg(math.atan2(diff.Y, diff.X))
            else
                data.Line.Visible = false
            end
            data.Arrow.Visible = false
        else
            data.Line.Visible = false
            if Library.Settings.Arrows then
                local relative = camCF:PointToObjectSpace(rootPos)
                local angle = math.atan2(-relative.X, -relative.Z)
                local radius = viewportSize.Y * 0.4
                
                data.Arrow.Visible = true
                data.Arrow.ImageColor3 = displayColor
                data.Arrow.Position = UDim2.new(0, screenCenter.X + math.sin(angle) * radius, 0, screenCenter.Y + math.cos(angle) * radius)
                data.Arrow.Rotation = math.deg(angle)
            else
                data.Arrow.Visible = false
            end
        end

    end
end
end)

return Library
