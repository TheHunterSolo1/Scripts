local Library = {
    Settings = {
        Tracers = true,
        Distance = true,
        MaxDistance = 5000,
        TextSize = 18,
        Font = Enum.Font.RobotoMono,
        Rainbow = false
    },
    Cache = {}
}

local RS = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local Screen = Instance.new("ScreenGui", CoreGui)
Screen.Name = "OmniESP"
Screen.IgnoreGuiInset = true

local function GetRoot(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    return obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")) or nil
end

function GenerateRandomString(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local res = ""
    for i = 1, length do
        local rand = math.random(1, #chars)
        res = res .. string.sub(chars, rand, rand)
    end
    return res
end

function Library:SetFont(font)
    self.Settings.Font = font
    for _, data in pairs(self.Cache) do data.Text.Font = font end
end

function Library:SetTracers(bool)
    self.Settings.Tracers = bool
end

function Library:SetShowDistance(bool)
    self.Settings.Distance = bool
end

function Library:SetRainbow(bool)
    self.Settings.Rainbow = bool
    if not bool then
        for _, data in pairs(self.Cache) do
            data.Text.TextColor3 = data.OriginalColor
            data.Line.BackgroundColor3 = data.OriginalColor
        end
    end
end

function Library:AddESP(cfg)
    local obj = cfg.Object
    local name = cfg.Text
    local color = cfg.Color

    if not obj or self.Cache[obj] then return end

    local billboard = Instance.new("BillboardGui", CoreGui)
    billboard.Name = GenerateRandomString(12)
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    
    local label = Instance.new("TextLabel", billboard)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.TextColor3 = color
    label.Font = self.Settings.Font
    label.TextSize = self.Settings.TextSize
    label.TextStrokeTransparency = 0

    local line = Instance.new("Frame", Screen)
    line.AnchorPoint = Vector2.new(0.5, 0.5)
    line.BorderSizePixel = 0
    line.BackgroundColor3 = color
    line.Visible = false

    self.Cache[obj] = {
        Tag = billboard,
        Text = label,
        Line = line,
        Name = name,
        OriginalColor = color
    }
end

function Library:RemoveESP(obj)
    local data = self.Cache[obj]
    if data then
        data.Tag:Destroy()
        data.Line:Destroy()
        self.Cache[obj] = nil
    end
end

function Library:Unload()
    if self.Connection then self.Connection:Disconnect() end
    for obj, _ in pairs(self.Cache) do self:RemoveESP(obj) end
    Screen:Destroy()
end

Library.Connection = RS.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local viewportSize = cam.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y)
    local fovScale = cam.FieldOfView / 70
    local hue = tick() % 10 / 10

    for obj, data in pairs(Library.Cache) do
        local root = GetRoot(obj)
        if not root or not obj.Parent then
            Library:RemoveESP(obj)
            continue
        end

        local pos = root.Position
        local screenPos, onScreen = cam:WorldToViewportPoint(pos)
        local dist = (cam.CFrame.Position - pos).Magnitude

        data.Tag.Adornee = root
        data.Text.TextSize = Library.Settings.TextSize * fovScale
        
        if Library.Settings.Rainbow then
            local rc = Color3.fromHSV(hue, 0.8, 1)
            data.Text.TextColor3 = rc
            data.Line.BackgroundColor3 = rc
        end

        data.Text.Text = string.format("%s%s", data.Name, 
            Library.Settings.Distance and string.format("\n[%dm]", math.floor(dist)) or "")
        
        if Library.Settings.Tracers and onScreen then
            local targetPos = Vector2.new(screenPos.X, screenPos.Y)
            local diff = targetPos - screenCenter
            
            data.Line.Visible = true
            data.Line.Size = UDim2.new(0, diff.Magnitude, 0, 1)
            data.Line.Position = UDim2.new(0, screenCenter.X + diff.X / 2, 0, screenCenter.Y + diff.Y / 2)
            data.Line.Rotation = math.deg(math.atan2(diff.Y, diff.X))
        else
            data.Line.Visible = false
        end
    end
end)

return Library
